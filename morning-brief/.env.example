OPENAI_API_KEY=

# Calendar source options:
# api = official Google Calendar API only
# browser = local Chrome browser automation only
# auto = try API first, fallback to browser
CALENDAR_SOURCE=auto

# Browser automation settings
GOOGLE_CALENDAR_URL=https://calendar.google.com/calendar/u/0/r/day
BROWSER_HEADLESS=false

# Gmail source options:
# api = official Gmail API only
# browser = local Chrome browser automation only
# auto = try API first, fallback to browser
GMAIL_SOURCE=auto

# Browser automation settings
GMAIL_URL=https://mail.google.com/mail/u/0
